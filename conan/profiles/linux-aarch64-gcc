{% set sysroot = os.getenv("SIGNLANG_AARCH64_SYSROOT", "/root/sysroot") %}
{% set target_triple = os.getenv("SIGNLANG_AARCH64_TARGET_TRIPLE", "aarch64-linux-gnu") %}
{% set toolchain_prefix = os.getenv("SIGNLANG_AARCH64_TOOLCHAIN_PREFIX", target_triple + "-") %}
{% set library_architecture = os.getenv("SIGNLANG_AARCH64_LIBRARY_ARCHITECTURE", target_triple) %}
{% set gcc_version = os.getenv("SIGNLANG_AARCH64_GCC_VERSION", "11") %}

[settings]
os=Linux
arch=armv8
compiler=gcc
compiler.version={{ gcc_version }}
compiler.libcxx=libstdc++11
compiler.cppstd=17
build_type=Release

[conf]
tools.build:compiler_executables={"c": "{{ toolchain_prefix }}gcc", "cpp": "{{ toolchain_prefix }}g++"}
tools.build:sysroot={{ sysroot }}
tools.cmake.cmaketoolchain:system_name=Linux
tools.cmake.cmaketoolchain:system_processor=aarch64
tools.cmake.cmaketoolchain:extra_variables={"CMAKE_SYSTEM_NAME": "Linux", "CMAKE_SYSTEM_PROCESSOR": "aarch64", "CMAKE_LIBRARY_ARCHITECTURE": "{{ library_architecture }}", "CMAKE_AR": "{{ toolchain_prefix }}ar", "CMAKE_RANLIB": "{{ toolchain_prefix }}ranlib", "CMAKE_NM": "{{ toolchain_prefix }}nm", "CMAKE_OBJCOPY": "{{ toolchain_prefix }}objcopy", "CMAKE_OBJDUMP": "{{ toolchain_prefix }}objdump", "CMAKE_READELF": "{{ toolchain_prefix }}readelf", "CMAKE_STRIP": "{{ toolchain_prefix }}strip", "CMAKE_FIND_ROOT_PATH": "{{ sysroot }}", "CMAKE_FIND_ROOT_PATH_MODE_PROGRAM": "NEVER", "CMAKE_FIND_ROOT_PATH_MODE_LIBRARY": "ONLY", "CMAKE_FIND_ROOT_PATH_MODE_INCLUDE": "ONLY", "CMAKE_FIND_ROOT_PATH_MODE_PACKAGE": "BOTH"}

[buildenv]
CHOST={{ target_triple }}
CC={{ toolchain_prefix }}gcc
CXX={{ toolchain_prefix }}g++
