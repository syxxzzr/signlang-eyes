{% set sysroot = os.getenv("SIGNLANG_AARCH64_SYSROOT", "/root/sysroot") %}
{% set gcc_version = os.getenv("SIGNLANG_AARCH64_GCC_VERSION", "11") %}

[settings]
os=Linux
arch=armv8
compiler=gcc
compiler.version={{ gcc_version }}
compiler.libcxx=libstdc++11
compiler.cppstd=17
build_type=Release

[conf]
tools.build:compiler_executables={"c": "aarch64-linux-gnu-gcc", "cpp": "aarch64-linux-gnu-g++"}
tools.build:sysroot={{ sysroot }}
tools.cmake.cmaketoolchain:system_name=Linux
tools.cmake.cmaketoolchain:system_processor=aarch64
tools.cmake.cmaketoolchain:extra_variables={"CMAKE_SYSTEM_NAME": "Linux", "CMAKE_SYSTEM_PROCESSOR": "aarch64", "CMAKE_AR": "aarch64-linux-gnu-ar", "CMAKE_RANLIB": "aarch64-linux-gnu-ranlib", "CMAKE_NM": "aarch64-linux-gnu-nm", "CMAKE_OBJCOPY": "aarch64-linux-gnu-objcopy", "CMAKE_OBJDUMP": "aarch64-linux-gnu-objdump", "CMAKE_READELF": "aarch64-linux-gnu-readelf", "CMAKE_STRIP": "aarch64-linux-gnu-strip"}

[buildenv]
CHOST=aarch64-linux-gnu
CC=aarch64-linux-gnu-gcc
CXX=aarch64-linux-gnu-g++
